# Copy this file to `.env` and set your real keys.
# REACT_APP_OPENAI_API_KEY: (optional) OpenAI API key to enable real AI analysis.
# If omitted, the app will use a safe mocked response for development.
REACT_APP_OPENAI_API_KEY=openapi_key

# Backend API base URL (defaults to http://localhost:4001/api)
REACT_APP_API_BASE=http://localhost:4001/api
